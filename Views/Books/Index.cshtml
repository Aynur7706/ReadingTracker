@model List<ReadingTracker.Models.Book>
@using ReadingTracker.Models

@{
    var total = Model.Count;
    var reading = Model.Count(x => x.Status == BookStatus.Oxunur);
    var completed = Model.Count(x => x.Status == BookStatus.Bitirilib);
    var percent = total == 0 ? 0 : (int)Math.Round((double)completed * 100 / total);
}

<section class="rounded-[34px] border border-[#e6ded2] bg-[#fbf6ed] p-5 shadow-soft">
    <div class="mb-6 overflow-hidden rounded-[30px] border border-[#e5d8c8] bg-[#f4eadb]">
        <div class="grid min-h-48 items-center gap-6 px-8 py-8 md:grid-cols-[1fr_1.3fr_1fr]">
            <div class="hidden items-end gap-3 md:flex">
                <div class="h-28 w-12 rounded-t-lg bg-[#6f4e37] shadow-md"></div>
                <div class="h-36 w-12 rounded-t-lg bg-[#15384f] shadow-md"></div>
                <div class="h-24 w-12 rounded-t-lg bg-[#8b6f47] shadow-md"></div>
                <div class="h-20 w-2 bg-[#2f241d]"></div>
            </div>
            <div class="text-center">
                <p class="text-xs font-bold uppercase tracking-[0.35em] text-[#8a6a43]">Your reading universe</p>
                <h1 class="mt-3 font-serif text-5xl font-black uppercase tracking-wide text-[#4a2f24] md:text-6xl">
                    The Literary Journal
                </h1>
                <p class="mt-3 text-sm font-semibold uppercase tracking-[0.25em] text-[#6f5a46]">Book Lover Dashboard</p>
            </div>
            <div class="hidden justify-end md:flex">
                <div class="rounded-3xl border border-[#dfd0bd] bg-white/50 p-5 text-[#4a2f24] shadow-sm">
                    <div class="text-5xl">☕</div>
                    <div class="mt-3 text-sm font-bold">Read. Reflect. Grow.</div>
                </div>
            </div>
        </div>
    </div>

    <div class="grid gap-5 lg:grid-cols-[210px_1fr]">
        <aside class="rounded-[28px] border border-[#e5d8c8] bg-[#f7efe4] p-5">
            <h2 class="mb-4 text-sm font-black uppercase tracking-wide text-[#4a2f24]">Book Lover Dashboard</h2>
            <nav class="space-y-1 text-sm font-semibold text-[#5f5144]">
                <a href="/books" class="block rounded-xl bg-[#eadfce] px-3 py-2 text-[#3d2a22]">Current Reads</a>
                <a href="/books?status=oxunur" class="block rounded-xl px-3 py-2 hover:bg-[#efe5d7]">Reading</a>
                <a href="/books?status=bitirilib" class="block rounded-xl px-3 py-2 hover:bg-[#efe5d7]">Completed</a>
                <a href="/books/create" class="block rounded-xl px-3 py-2 hover:bg-[#efe5d7]">Add Book</a>
            </nav>

            <div class="mt-8 space-y-4 text-sm text-[#5f5144]">
                <div>
                    <p class="font-black uppercase text-[#4a2f24]">My Library</p>
                    <p class="mt-2">Books, goals, progress and reading notes in one quiet workspace.</p>
                </div>
                <div>
                    <p class="font-black uppercase text-[#4a2f24]">Wishlist</p>
                    <p class="mt-2">Keep future reads organized.</p>
                </div>
            </div>
        </aside>

        <main class="space-y-5">
            <div class="grid gap-5 xl:grid-cols-[1.5fr_0.8fr]">
                <section class="rounded-[28px] border border-[#e5d8c8] bg-white/70 p-5">
                    <div class="mb-4 flex items-center justify-between border-b border-[#eadfce] pb-3">
                        <h3 class="text-lg font-black uppercase text-[#3d2a22]">Currently Reading</h3>
                        <a href="/books/create" class="rounded-xl bg-[#3d2a22] px-4 py-2 text-sm font-bold text-white transition hover:bg-[#5a4034]">
                            Add book
                        </a>
                    </div>

                    @if (!Model.Any())
                    {
                        <div class="rounded-2xl border border-dashed border-[#d7c8b5] bg-[#fbf6ed] p-8 text-center">
                            <p class="text-xl font-black text-[#3d2a22]">No books yet</p>
                            <p class="mt-2 text-[#6f5a46]">Add your first book to start tracking.</p>
                        </div>
                    }
                    else
                    {
                        <div class="grid gap-4 md:grid-cols-3">
                            @foreach (var book in Model.Take(3))
                            {
                                <article class="rounded-2xl border border-[#e8dccd] bg-[#fbf6ed] p-3 shadow-sm">
                                    <div class="flex h-40 items-center justify-center rounded-xl bg-gradient-to-br from-[#2f4d5f] to-[#b28b57] text-center text-white shadow-inner">
                                        <div>
                                            <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-xl bg-white/20 text-2xl font-black">R</div>
                                            <p class="px-3 text-sm font-black leading-tight">@book.Title</p>
                                        </div>
                                    </div>
                                    <div class="mt-3">
                                        <a href="/books/@book.Id" class="line-clamp-1 font-black text-[#3d2a22] hover:underline">@book.Title</a>
                                        <p class="mt-1 text-sm text-[#6f5a46]">@book.Author</p>
                                        <div class="mt-3 flex items-center justify-between text-xs text-[#6f5a46]">
                                            <span>★★★★★</span>
                                            <span>@(book.Status == BookStatus.Oxunur ? "Reading" : "Done")</span>
                                        </div>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </section>

                <section class="rounded-[28px] border border-[#e5d8c8] bg-white/70 p-5">
                    <h3 class="mb-4 border-b border-[#eadfce] pb-3 text-lg font-black uppercase text-[#3d2a22]">Reading Progress</h3>
                    <div class="flex items-center justify-center py-4">
                        <div class="relative grid h-44 w-44 place-items-center rounded-full" style="background: conic-gradient(#24475f @(percent)%, #e6ded2 0);">
                            <div class="grid h-32 w-32 place-items-center rounded-full bg-white text-center">
                                <div>
                                    <p class="text-3xl font-black text-[#3d2a22]">@percent%</p>
                                    <p class="text-xs font-bold uppercase text-[#6f5a46]">Completed</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="grid grid-cols-3 gap-2 text-center">
                        <div class="rounded-xl bg-[#fbf6ed] p-3">
                            <p class="text-xl font-black">@total</p>
                            <p class="text-xs text-[#6f5a46]">Total</p>
                        </div>
                        <div class="rounded-xl bg-[#fbf6ed] p-3">
                            <p class="text-xl font-black">@reading</p>
                            <p class="text-xs text-[#6f5a46]">Reading</p>
                        </div>
                        <div class="rounded-xl bg-[#fbf6ed] p-3">
                            <p class="text-xl font-black">@completed</p>
                            <p class="text-xs text-[#6f5a46]">Done</p>
                        </div>
                    </div>
                </section>
            </div>

            <div class="grid gap-5 xl:grid-cols-[1fr_0.8fr]">
                <section class="rounded-[28px] border border-[#e5d8c8] bg-white/70 p-5">
                    <h3 class="mb-4 border-b border-[#eadfce] pb-3 text-lg font-black uppercase text-[#3d2a22]">Reading Log</h3>
                    <div class="grid grid-cols-7 gap-2 text-center text-sm">
                        @foreach (var day in new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" })
                        {
                            <div class="font-bold text-[#6f5a46]">@day</div>
                        }
                        @for (var i = 1; i <= 28; i++)
                        {
                            <div class="rounded-xl border border-[#eadfce] bg-[#fbf6ed] p-2 text-[#4a2f24]">
                                <span class="text-xs">@i</span>
                                @if (i % 4 == 0)
                                {
                                    <div class="mx-auto mt-1 h-5 w-4 rounded-sm bg-[#8b6f47]"></div>
                                }
                            </div>
                        }
                    </div>
                </section>

                <section class="rounded-[28px] border border-[#e5d8c8] bg-white/70 p-5">
                    <h3 class="mb-4 border-b border-[#eadfce] pb-3 text-lg font-black uppercase text-[#3d2a22]">Bookish Bucket List</h3>
                    <div class="grid gap-3 sm:grid-cols-2">
                        @foreach (var book in Model.Skip(1).Take(4))
                        {
                            <a href="/books/@book.Id" class="rounded-2xl border border-[#eadfce] bg-[#fbf6ed] p-3 transition hover:-translate-y-1 hover:shadow-md">
                                <div class="h-24 rounded-xl bg-gradient-to-br from-[#15384f] to-[#b28b57]"></div>
                                <p class="mt-2 line-clamp-1 text-sm font-black text-[#3d2a22]">@book.Title</p>
                                <span class="mt-2 inline-flex rounded-lg border border-[#e5d8c8] bg-white px-2 py-1 text-xs text-[#6f5a46]">Genre</span>
                            </a>
                        }
                    </div>
                </section>
            </div>

            <div class="grid gap-5 xl:grid-cols-[1fr_0.8fr]">
                <section class="rounded-[28px] border border-[#e5d8c8] bg-white/70 p-6 text-center">
                    <h3 class="mb-4 text-lg font-black uppercase text-[#3d2a22]">Favorite Quote</h3>
                    <p class="font-serif text-xl italic leading-8 text-[#4a2f24]">
                        “A reader lives a thousand lives before he dies.”
                    </p>
                    <p class="mt-3 text-sm font-semibold text-[#6f5a46]">George R. R. Martin</p>
                </section>

                <section class="rounded-[28px] border border-[#e5d8c8] bg-white/70 p-5">
                    <h3 class="mb-4 text-lg font-black uppercase text-[#3d2a22]">Notes & Reflections</h3>
                    <textarea class="h-32 w-full resize-none rounded-2xl border border-[#e5d8c8] bg-[#fbf6ed] p-4 text-sm outline-none focus:border-[#8b6f47]" placeholder="Write your reflections..."></textarea>
                </section>
            </div>
        </main>
    </div>
</section>
