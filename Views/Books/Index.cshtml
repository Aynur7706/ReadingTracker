@model List<ReadingTracker.Models.Book>
@using ReadingTracker.Models

<div class="hero-box mb-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
            <h1 class="fw-bold mb-2">Mənim kitab rəfim</h1>
            <p class="mb-0 text-white-50">
                Oxuduğun kitabları əlavə et, statusunu dəyiş və oxuma prosesini izlə.
            </p>
        </div>

        <a href="/books/create" class="btn btn-warning rounded-4 px-4 py-3 fw-semibold">
            <i class="bi bi-plus-circle"></i>
            Yeni kitab əlavə et
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card main-card">
            <div class="card-body">
                <p class="text-muted mb-1">Ümumi kitab</p>
                <h3 class="fw-bold mb-0">@Model.Count</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card main-card">
            <div class="card-body">
                <p class="text-muted mb-1">Oxunur</p>
                <h3 class="fw-bold mb-0">@Model.Count(x => x.Status == BookStatus.Oxunur)</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card main-card">
            <div class="card-body">
                <p class="text-muted mb-1">Bitirilib</p>
                <h3 class="fw-bold mb-0">@Model.Count(x => x.Status == BookStatus.Bitirilib)</h3>
            </div>
        </div>
    </div>
</div>

<div class="card main-card mb-4">
    <div class="card-body d-flex gap-2 flex-wrap">
        <a href="/books"
           class="btn @(ViewBag.CurrentStatus == null ? "btn-dark" : "btn-outline-dark") rounded-4">
            Hamısı
        </a>

        <a href="/books?status=oxunur"
           class="btn @(ViewBag.CurrentStatus == "oxunur" ? "btn-warning" : "btn-outline-warning") rounded-4">
            Yalnız oxunanlar
        </a>

        <a href="/books?status=bitirilib"
           class="btn @(ViewBag.CurrentStatus == "bitirilib" ? "btn-success" : "btn-outline-success") rounded-4">
            Yalnız bitirilənlər
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card main-card">
        <div class="card-body text-center py-5">
            <i class="bi bi-journal-bookmark display-3 text-muted"></i>
            <h4 class="fw-bold mt-3">Hələ kitab əlavə edilməyib</h4>
            <p class="text-muted">İlk kitabını əlavə et və oxuma izləməyə başla.</p>
            <a href="/books/create" class="btn btn-dark rounded-4 px-4">
                Kitab əlavə et
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var book in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card main-card book-card h-100">
                    <div class="card-body p-4">

                        <div class="d-flex justify-content-between align-items-start mb-4">
                            <div class="rounded-4 d-flex align-items-center justify-content-center"
                                 style="width:52px;height:52px;background:#fef3c7;">
                                <i class="bi bi-book fs-4 text-warning"></i>
                            </div>

                            @if (book.Status == BookStatus.Oxunur)
                            {
                                <span class="badge bg-warning text-dark rounded-pill px-3 py-2">
                                    Oxunur
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success rounded-pill px-3 py-2">
                                    Bitirilib
                                </span>
                            }
                        </div>

                        <h4 class="fw-bold mb-2">@book.Title</h4>

                        <p class="text-muted mb-4">
                            <i class="bi bi-person"></i>
                            @book.Author
                        </p>

                        @if (book.Status == BookStatus.Oxunur)
                        {
                            <form method="post" action="/books/finish/@book.Id">
                                <button class="btn btn-success w-100 rounded-4 py-2 fw-semibold">
                                    <i class="bi bi-check-circle"></i>
                                    Bitirilib et
                                </button>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-outline-success w-100 rounded-4 py-2" disabled>
                                <i class="bi bi-lock"></i>
                                Artıq bitirilib
                            </button>
                        }

                    </div>
                </div>
            </div>
        }
    </div>
}