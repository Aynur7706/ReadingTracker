@model List<ReadingTracker.Models.Book>
@using ReadingTracker.Models

<section class="space-y-8">
    <div class="overflow-hidden rounded-[32px] bg-slate-950 p-8 text-white shadow-soft">
        <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
            <div>
                <p class="mb-3 text-xs font-bold uppercase tracking-[0.25em] text-amber-300">Reading dashboard</p>
                <h1 class="text-4xl font-black tracking-tight md:text-5xl">Mənim kitab rəfim</h1>
                <p class="mt-4 max-w-2xl text-base leading-7 text-slate-300">
                    Oxuduğun kitabları əlavə et, statusunu dəyiş və oxuma prosesini izlə.
                </p>
            </div>

            <a href="/books/create" class="inline-flex items-center justify-center rounded-2xl bg-accent px-5 py-3 font-bold text-slate-950 transition hover:bg-yellow-300">
                Yeni kitab əlavə et
            </a>
        </div>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
            <p class="text-sm font-semibold text-slate-500">Ümumi kitab</p>
            <h3 class="mt-2 text-4xl font-black text-slate-950">@Model.Count</h3>
        </div>
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
            <p class="text-sm font-semibold text-slate-500">Oxunur</p>
            <h3 class="mt-2 text-4xl font-black text-slate-950">@Model.Count(x => x.Status == BookStatus.Oxunur)</h3>
        </div>
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
            <p class="text-sm font-semibold text-slate-500">Bitirilib</p>
            <h3 class="mt-2 text-4xl font-black text-slate-950">@Model.Count(x => x.Status == BookStatus.Bitirilib)</h3>
        </div>
    </div>

    <div class="flex flex-wrap gap-2 rounded-3xl border border-slate-200 bg-white p-3 shadow-sm">
        <a href="/books" class="rounded-2xl px-4 py-2 text-sm font-bold transition @(ViewBag.CurrentStatus == null ? "bg-slate-950 text-white" : "text-slate-600 hover:bg-slate-100")">
            Hamısı
        </a>
        <a href="/books?status=oxunur" class="rounded-2xl px-4 py-2 text-sm font-bold transition @(ViewBag.CurrentStatus == "oxunur" ? "bg-accent text-slate-950" : "text-slate-600 hover:bg-slate-100")">
            Yalnız oxunanlar
        </a>
        <a href="/books?status=bitirilib" class="rounded-2xl px-4 py-2 text-sm font-bold transition @(ViewBag.CurrentStatus == "bitirilib" ? "bg-emerald-600 text-white" : "text-slate-600 hover:bg-slate-100")">
            Yalnız bitirilənlər
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="rounded-[28px] border border-dashed border-slate-300 bg-white p-10 text-center shadow-sm">
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-100 text-2xl font-black text-slate-500">R</div>
            <h4 class="mt-4 text-2xl font-black text-slate-950">Hələ kitab əlavə edilməyib</h4>
            <p class="mt-2 text-slate-500">İlk kitabını əlavə et və oxuma izləməyə başla.</p>
            <a href="/books/create" class="mt-6 inline-flex rounded-2xl bg-slate-950 px-5 py-3 font-bold text-white transition hover:bg-slate-800">
                Kitab əlavə et
            </a>
        </div>
    }
    else
    {
        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
            @foreach (var book in Model)
            {
                <article class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-soft">
                    <div class="mb-6 flex items-start justify-between">
                        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-amber-100 text-xl font-black text-amber-700">R</div>

                        @if (book.Status == BookStatus.Oxunur)
                        {
                            <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-bold text-amber-800">Oxunur</span>
                        }
                        else
                        {
                            <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-bold text-emerald-700">Bitirilib</span>
                        }
                    </div>

                    <h4 class="text-xl font-black tracking-tight text-slate-950">@book.Title</h4>
                    <p class="mt-2 text-sm text-slate-500">@book.Author</p>

                    @if (book.Status == BookStatus.Oxunur)
                    {
                        <div class="mt-6 grid grid-cols-2 gap-2">
                            <a href="/books/@book.Id" class="rounded-2xl border border-slate-300 px-4 py-3 text-center text-sm font-bold text-slate-700 transition hover:border-slate-950 hover:text-slate-950">
                                Details
                            </a>
                            <form method="post" action="/books/finish/@book.Id">
                                <button class="w-full rounded-2xl bg-emerald-600 px-4 py-3 text-sm font-bold text-white transition hover:bg-emerald-700">
                                    Bitirilib et
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="mt-6 grid grid-cols-2 gap-2">
                            <a href="/books/@book.Id" class="rounded-2xl border border-slate-300 px-4 py-3 text-center text-sm font-bold text-slate-700 transition hover:border-slate-950 hover:text-slate-950">
                                Details
                            </a>
                            <button class="rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-bold text-emerald-700" disabled>
                                Bitirilib
                            </button>
                        </div>
                    }
                </article>
            }
        </div>
    }
</section>
