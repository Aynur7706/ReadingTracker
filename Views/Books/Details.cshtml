@model ReadingTracker.Models.Book
@using ReadingTracker.Models

<section class="mx-auto max-w-6xl">
    <div class="mb-6 flex items-center justify-between">
        <a href="/books" class="rounded-2xl border border-slate-300 bg-white px-4 py-2 text-sm font-bold text-slate-600 shadow-sm transition hover:border-slate-950 hover:text-slate-950">
            Geri qayıt
        </a>
        <span class="text-sm font-semibold text-slate-500">Reading Tracker / Book Details</span>
    </div>

    <div class="grid overflow-hidden rounded-[34px] border border-slate-200 bg-white shadow-soft lg:grid-cols-[380px_1fr]">
        <aside class="relative bg-slate-950 p-8 text-white">
            <div class="absolute inset-0 opacity-20">
                <div class="absolute -left-16 top-16 h-52 w-52 rounded-full bg-amber-300 blur-3xl"></div>
                <div class="absolute bottom-8 right-0 h-56 w-56 rounded-full bg-emerald-400 blur-3xl"></div>
            </div>

            <div class="relative">
                <p class="mb-6 text-xs font-bold uppercase tracking-[0.25em] text-amber-300">Selected book</p>

                <div class="rounded-[30px] border border-white/10 bg-white/10 p-6 shadow-2xl backdrop-blur">
                    <div class="mb-10 flex h-24 w-24 items-center justify-center rounded-3xl bg-amber-300 text-4xl font-black text-slate-950">
                        R
                    </div>
                    <h1 class="text-4xl font-black leading-tight tracking-tight">@Model.Title</h1>
                    <p class="mt-4 text-lg text-slate-300">@Model.Author</p>
                </div>

                <div class="mt-6 rounded-3xl border border-white/10 bg-white/5 p-5">
                    <p class="text-sm font-semibold text-slate-400">Current status</p>
                    @if (Model.Status == BookStatus.Oxunur)
                    {
                        <span class="mt-3 inline-flex rounded-full bg-amber-100 px-4 py-2 text-sm font-black text-amber-800">Oxunur</span>
                    }
                    else
                    {
                        <span class="mt-3 inline-flex rounded-full bg-emerald-100 px-4 py-2 text-sm font-black text-emerald-700">Bitirilib</span>
                    }
                </div>
            </div>
        </aside>

        <div class="p-8 lg:p-10">
            <div class="mb-8">
                <p class="mb-3 text-xs font-bold uppercase tracking-[0.25em] text-amber-600">Overview</p>
                <h2 class="text-3xl font-black tracking-tight text-slate-950">Book information</h2>
                <p class="mt-3 max-w-2xl text-slate-500">
                    Bu səhifə seçilmiş kitabın əsas məlumatlarını və oxuma statusunu göstərir.
                </p>
            </div>

            <div class="grid gap-4 md:grid-cols-3">
                <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
                    <p class="text-sm font-semibold text-slate-500">Book ID</p>
                    <p class="mt-3 text-3xl font-black text-slate-950">#@Model.Id</p>
                </div>
                <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
                    <p class="text-sm font-semibold text-slate-500">Author</p>
                    <p class="mt-3 text-lg font-black text-slate-950">@Model.Author</p>
                </div>
                <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
                    <p class="text-sm font-semibold text-slate-500">Status</p>
                    <p class="mt-3 text-lg font-black text-slate-950">@Model.Status</p>
                </div>
            </div>

            <div class="mt-8 rounded-3xl border border-slate-200 bg-white p-6">
                <h3 class="text-xl font-black tracking-tight text-slate-950">Reading action</h3>
                <p class="mt-2 text-sm leading-6 text-slate-500">
                    Kitab hələ oxunursa, onu bir kliklə bitirilmiş kimi işarələyə bilərsən.
                </p>

                @if (Model.Status == BookStatus.Oxunur)
                {
                    <form method="post" action="/books/finish/@Model.Id" class="mt-5">
                        <button class="rounded-2xl bg-emerald-600 px-5 py-3 font-bold text-white transition hover:bg-emerald-700">
                            Bitirilib et
                        </button>
                    </form>
                }
                else
                {
                    <div class="mt-5 rounded-2xl border border-emerald-200 bg-emerald-50 px-5 py-4 font-bold text-emerald-700">
                        Bu kitab artıq bitirilib.
                    </div>
                }
            </div>
        </div>
    </div>
</section>
