@model ReadingTracker.Models.BookCreateViewModel

<div class="row justify-content-center">
    <div class="col-lg-7">

        <div class="card main-card">
            <div class="card-body p-5">

                <div class="mb-4">
                    <a href="/books" class="text-decoration-none text-muted">
                        <i class="bi bi-arrow-left"></i>
                        Geri qayıt
                    </a>
                </div>

                <div class="mb-4">
                    <h2 class="fw-bold mb-2">Yeni kitab əlavə et</h2>
                    <p class="text-muted mb-0">
                        Əlavə etdiyiniz kitab avtomatik olaraq sizin hesabınıza bağlanacaq.
                    </p>
                </div>

                <form method="post">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Kitabın adı</label>
                        <input asp-for="Title" class="form-control rounded-4" placeholder="Məsələn: Clean Code" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Müəllif</label>
                        <input asp-for="Author" class="form-control rounded-4" placeholder="Məsələn: Robert C. Martin" />
                        <span asp-validation-for="Author" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-dark rounded-4 px-4 py-3 fw-semibold">
                            <i class="bi bi-plus-circle"></i>
                            Əlavə et
                        </button>

                        <a href="/books" class="btn btn-outline-secondary rounded-4 px-4 py-3">
                            Ləğv et
                        </a>
                    </div>
                </form>

            </div>
        </div>

    </div>
</div>