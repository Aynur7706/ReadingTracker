@model ReadingTracker.Models.BookCreateViewModel

<section class="mx-auto max-w-3xl">
    <div class="rounded-[28px] border border-[#e5d8c8] bg-white p-8 shadow-soft">
        <div class="mb-6">
            <a href="/books" class="text-sm font-bold text-[#6f5a46] transition hover:text-[#3d2a22]">
                Geri qayıt
            </a>
        </div>

        <div class="mb-8">
            <p class="mb-3 text-xs font-bold uppercase tracking-[0.25em] text-[#8a6a43]">New book</p>
            <h2 class="text-3xl font-black tracking-tight text-[#3d2a22]">Yeni kitab əlavə et</h2>
            <p class="mt-2 text-slate-500">
                Əlavə etdiyiniz kitab avtomatik olaraq sizin hesabınıza bağlanacaq.
            </p>
        </div>

        <form method="post" class="space-y-5">
            <div>
                <label class="mb-2 block text-sm font-bold text-slate-800">Kitabın adı</label>
                <input asp-for="Title" class="w-full rounded-2xl border border-[#e5d8c8] bg-white px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-[#6f4e37] focus:ring-4 focus:ring-[#eadfce]" placeholder="Məsələn: Clean Code" />
                <span asp-validation-for="Title" class="mt-1 block text-sm text-red-600"></span>
            </div>

            <div>
                <label class="mb-2 block text-sm font-bold text-slate-800">Müəllif</label>
                <input asp-for="Author" class="w-full rounded-2xl border border-[#e5d8c8] bg-white px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-[#6f4e37] focus:ring-4 focus:ring-[#eadfce]" placeholder="Məsələn: Robert C. Martin" />
                <span asp-validation-for="Author" class="mt-1 block text-sm text-red-600"></span>
            </div>

            <div class="flex flex-wrap gap-3 pt-2">
                <button class="rounded-2xl bg-[#3d2a22] px-5 py-3 font-bold text-white transition hover:bg-[#5a4034]">
                    Əlavə et
                </button>
                <a href="/books" class="rounded-2xl border border-[#d8c9b8] px-5 py-3 font-bold text-[#5f5144] transition hover:border-[#3d2a22] hover:text-[#3d2a22]">
                    Ləğv et
                </a>
            </div>
        </form>
    </div>
</section>
