@model ReadingTracker.Models.BookCreateViewModel

<section class="mx-auto max-w-3xl">
    <div class="rounded-[28px] border border-slate-200 bg-white p-8 shadow-soft">
        <div class="mb-6">
            <a href="/books" class="text-sm font-bold text-slate-500 transition hover:text-slate-950">
                Geri qayıt
            </a>
        </div>

        <div class="mb-8">
            <p class="mb-3 text-xs font-bold uppercase tracking-[0.25em] text-amber-600">New book</p>
            <h2 class="text-3xl font-black tracking-tight text-slate-950">Yeni kitab əlavə et</h2>
            <p class="mt-2 text-slate-500">
                Əlavə etdiyiniz kitab avtomatik olaraq sizin hesabınıza bağlanacaq.
            </p>
        </div>

        <form method="post" class="space-y-5">
            <div>
                <label class="mb-2 block text-sm font-bold text-slate-800">Kitabın adı</label>
                <input asp-for="Title" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-slate-950 focus:ring-4 focus:ring-slate-200" placeholder="Məsələn: Clean Code" />
                <span asp-validation-for="Title" class="mt-1 block text-sm text-red-600"></span>
            </div>

            <div>
                <label class="mb-2 block text-sm font-bold text-slate-800">Müəllif</label>
                <input asp-for="Author" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-slate-950 focus:ring-4 focus:ring-slate-200" placeholder="Məsələn: Robert C. Martin" />
                <span asp-validation-for="Author" class="mt-1 block text-sm text-red-600"></span>
            </div>

            <div class="flex flex-wrap gap-3 pt-2">
                <button class="rounded-2xl bg-slate-950 px-5 py-3 font-bold text-white transition hover:bg-slate-800">
                    Əlavə et
                </button>
                <a href="/books" class="rounded-2xl border border-slate-300 px-5 py-3 font-bold text-slate-700 transition hover:border-slate-950 hover:text-slate-950">
                    Ləğv et
                </a>
            </div>
        </form>
    </div>
</section>
