<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <title>Reading Tracker</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        ink: "#111827",
                        paper: "#FBF6ED",
                        accent: "#6F4E37",
                        leather: "#3D2A22"
                    },
                    boxShadow: {
                        soft: "0 20px 60px rgba(15, 23, 42, 0.10)"
                    }
                }
            }
        }
    </script>
</head>
<body class="min-h-screen bg-paper text-ink antialiased">
    <header class="border-b border-[#e5d8c8] bg-white/85 backdrop-blur">
        <nav class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
            <a class="flex items-center gap-3 font-semibold tracking-tight text-[#3d2a22]" href="/books">
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent text-sm font-black text-white">R</span>
                <span class="text-xl">Reading Tracker</span>
            </a>

            <div class="flex items-center gap-2">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <span class="hidden text-sm text-slate-500 md:inline">
                        @User.FindFirst("FullName")?.Value
                    </span>
                    <a href="/logout" class="rounded-xl border border-[#d8c9b8] px-4 py-2 text-sm font-semibold text-[#5f5144] transition hover:border-[#3d2a22] hover:text-[#3d2a22]">
                        Çıxış
                    </a>
                }
                else
                {
                    <a href="/login" class="rounded-xl border border-[#d8c9b8] px-4 py-2 text-sm font-semibold text-[#5f5144] transition hover:border-[#3d2a22] hover:text-[#3d2a22]">Login</a>
                    <a href="/register" class="rounded-xl bg-accent px-4 py-2 text-sm font-semibold text-white transition hover:bg-[#5a4034]">Qeydiyyat</a>
                }
            </div>
        </nav>
    </header>

    <main class="mx-auto max-w-6xl px-5 py-10">
        @RenderBody()
    </main>
</body>
</html>
