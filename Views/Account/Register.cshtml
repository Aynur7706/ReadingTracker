@model ReadingTracker.Models.RegisterViewModel

<div class="row justify-content-center align-items-center">
    <div class="col-lg-5">

        <div class="card main-card">
            <div class="card-body p-5">

                <div class="text-center mb-4">
                    <div class="brand-icon mx-auto mb-3">R</div>
                    <h2 class="fw-bold">Qeydiyyat</h2>
                    <p class="text-muted">Yeni hesab yaradın və kitablarınızı izləyin</p>
                </div>

                <form method="post">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Ad və soyad</label>
                        <input asp-for="FullName" class="form-control rounded-4" placeholder="Adınızı daxil edin" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Username</label>
                        <input asp-for="Username" class="form-control rounded-4" placeholder="Username seçin" />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Şifrə</label>
                        <input asp-for="Password" type="password" class="form-control rounded-4" placeholder="Minimum 4 simvol" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <button class="btn btn-dark w-100 rounded-4 py-3 fw-semibold">
                        <i class="bi bi-person-plus"></i>
                        Qeydiyyatdan keç
                    </button>
                </form>

                <p class="text-center mt-4 mb-0">
                    Artıq hesabın var?
                    <a href="/login" class="fw-semibold text-decoration-none">Daxil ol</a>
                </p>

            </div>
        </div>

    </div>
</div>