@model ReadingTracker.Models.LoginViewModel

<div class="row justify-content-center align-items-center">
    <div class="col-lg-5">

        <div class="card main-card">
            <div class="card-body p-5">

                <div class="text-center mb-4">
                    <div class="brand-icon mx-auto mb-3">R</div>
                    <h2 class="fw-bold">Daxil ol</h2>
                    <p class="text-muted">Kitablarını izləməyə davam et</p>
                </div>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Username</label>
                        <input asp-for="Username" class="form-control rounded-4" placeholder="Məsələn: user" />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Şifrə</label>
                        <input asp-for="Password" type="password" class="form-control rounded-4" placeholder="Məsələn: 1234" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <button class="btn btn-dark w-100 rounded-4 py-3 fw-semibold">
                        <i class="bi bi-box-arrow-in-right"></i>
                        Daxil ol
                    </button>
                </form>

                <p class="text-center mt-4 mb-0">
                    Hesabın yoxdur?
                    <a href="/register" class="fw-semibold text-decoration-none">Qeydiyyatdan keç</a>
                </p>

            </div>
        </div>

    </div>
</div>